# Copy to .env and fill in your values

# Web app
SESSION_SECRET=change_me_to_a_long_random_string
PORT=3000

# PostgreSQL
PGPASSWORD=change_me_db_password

# EVE Online SSO
# Register at https://developers.eveonline.com/
# Set callback URL to https://your-domain.com/auth/callback
EVE_CLIENT_ID=your_eve_app_client_id
EVE_CLIENT_SECRET=your_eve_app_client_secret
EVE_CALLBACK_URL=https://your-domain.com/auth/callback

# TeamSpeak 3 ServerQuery
TS3_HOST=your.teamspeak.server
TS3_QUERY_PORT=10011
TS3_SERVER_PORT=9987
TS3_USERNAME=serveradmin
TS3_PASSWORD=your_serverquery_password
TS3_BOT_NICKNAME=AuthBot

# Comma-separated EVE character IDs with admin access (no spaces)
ADMIN_CHARACTER_IDS=12345678,87654321
